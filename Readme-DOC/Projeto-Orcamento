Helpers

norm() — normaliza strings p/ classificação de tipo

cabeNaFolhaPassepartout() — valida folha (102 × 152 com giro)

classificaDiverso() — interpreta o nome do serviço Diversos e liga “flags”:
function classificaDiverso(d) {
  const n = (d?.nome || '').toLowerCase();
  return {
    precisaChassi: /troca\s*de\s*chassi/.test(n),
    precisaCanvas: /canvas/.test(n),
    precisaMatte: /(papel\s*matte|matte|fosco)/.test(n),
    precisaMoldura: /troca\s*de\s*moldura/.test(n),
    precisaVidro: /troca\s*de\s*vidro/.test(n),
    ehRetirarArte: /retirar\s*a\s*arte/.test(n),
  };
}



