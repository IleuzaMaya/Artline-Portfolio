Controller (se precisar):
// controllers/diversosController.js
import db from '../config/db.js';

export async function getDiversos(req, res) {
  try {
    const { ativo, tipo_orcamento_id } = req.query;
    const cond = [], params = [];
    if (ativo !== undefined) { cond.push('d.ativo = ?'); params.push(Number(ativo) ? 1 : 0); }
    if (tipo_orcamento_id) { cond.push('d.tipo_orcamento_id = ?'); params.push(tipo_orcamento_id); }
    const where = cond.length ? `WHERE ${cond.join(' AND ')}` : '';
    const sql = `
      SELECT d.id, d.nome, d.faixa_aplicacao, d.preco, d.ativo
      FROM mt_diversos d
      ${where}
      ORDER BY d.nome
    `;
    const [rows] = await db.query(sql, params);
    res.json(rows);
  } catch (e) {
    console.error(e); res.status(500).json({ error: 'Erro ao listar diversos.' });
  }
}

2.2. Catálogo consolidado (novo)

GET /api/diversos/catalog → devolve as 6 categorias já “agrupadas” com preços até/acima 50cm.
// controllers/diversosController.js (adicione)
export async function getDiversosCatalog(req, res) {
  try {
    const [rows] = await db.query(`
      SELECT id, nome, faixa_aplicacao, preco, IFNULL(ativo,1) AS ativo
      FROM mt_diversos
      WHERE IFNULL(ativo,1) = 1
    `);

    const CATS = [
      { key: 'troca_canvas',  label: 'Troca de Canvas',   match: /troca.*canvas/i },
      { key: 'troca_matte',   label: 'Troca de Papel Matte', match: /troca.*(papel\s*matte|matte|mate|fosco)/i },
      { key: 'troca_chassi',  label: 'Troca de Chassis',  match: /troca.*chassi/i },
      { key: 'troca_moldura', label: 'Troca de Moldura',  match: /troca.*moldura/i },
      { key: 'troca_vidro',   label: 'Troca de Vidro',    match: /troca.*vidro/i },
      { key: 'retirar_arte',  label: 'Retirar arte',      match: /retirar.*arte/i },
    ];

    const out = CATS.map(c => ({ key: c.key, label: c.label, ate50: null, acima50: null }));

    const isAte50 = (faixa = '') => {
      const f = String(faixa).toLowerCase();
      return f.includes('até') || f.includes('ate') || f.includes('50');
    };

    rows.forEach(r => {
      const cat = CATS.find(c => c.match.test(r.nome || ''));
      if (!cat) return;
      const bucket = out.find(o => o.key === cat.key);
      const node = { id: r.id, nome: r.nome, preco: Number(r.preco || 0), faixa: r.faixa_aplicacao || null };
      if (cat.key === 'retirar_arte') {
        bucket.ate50 = node; bucket.acima50 = node; // preço único
      } else if (isAte50(r.faixa_aplicacao)) {
        bucket.ate50 = node;
      } else {
        bucket.acima50 = node;
      }
    });

    res.json(out);
  } catch (e) {
    console.error(e); res.status(500).json({ error: 'Erro ao montar catálogo de diversos.' });
  }
}

